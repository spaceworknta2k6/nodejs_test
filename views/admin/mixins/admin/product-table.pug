mixin actionButtons(item)
    .action-group
        a.action-btn.action-btn--edit(href=`${PrefixAdmin}/product/edit/${item.id}`) Sửa
        button.action-btn.action-btn--delete(type="button" data-id=item._id) Xóa

mixin productTableRow(item, index)
    -
        const statusText = String(item && item.active ? item.active : '').toLowerCase().trim();
        const isActive = ['active', 'on', 'true', '1', 'hoat-dong'].includes(statusText) || item.active === true;
        const thumb = item.thumbnail || (item.images && item.images.length ? item.images[0] : 'https://placehold.co/120x120?text=No+Image');
        const shortDesc = item.description || 'Chưa có mô tả sản phẩm';
        const priceText = typeof item.price === 'number' ? item.price.toLocaleString('en-US') + ' USD' : 'Đang cập nhật';
        const ratingText = item.rating ? item.rating + ' / 5' : 'Chưa có';
        const positionValue = item.position || index + 1;

    tr
        td.select-cell
            input.row-checkbox(type="checkbox" name="selectedProducts[]" value=item._id)
        td
            .product-media
                img.product-thumb(src=thumb, alt=item.title || 'product')
                div
                    .product-name= item.title || 'Chưa có tên sản phẩm'
                    .product-desc= shortDesc
        td
            span.chip.chip--category= item.category || 'Chưa phân loại'
        td
            .price-box= priceText
            if item.discountPercentage
                .price-sale Giảm #{item.discountPercentage}%
        td
            .rating-box= ratingText
            .rating-sub Mã SP: #{item._id || index + 1}
        td
            label.switch
                input.status-toggle(
                    type="checkbox",
                    checked=isActive,
                    data-id=item._id
                )
                span.slider
        td
            input.position-input(
                type="number"
                min="1"
                step="1"
                value=positionValue
                data-id=item._id
                name="position"
            )
        td
            +actionButtons(item)

mixin productMobileCard(item, index)
    -
        const statusText = String(item && item.active ? item.active : '').toLowerCase().trim();
        const isActive = ['active', 'on', 'true', '1', 'hoat-dong'].includes(statusText) || item.active === true;
        const thumb = item.thumbnail || (item.images && item.images.length ? item.images[0] : 'https://placehold.co/120x120?text=No+Image');
        const shortDesc = item.description || 'Chưa có mô tả sản phẩm';
        const priceText = typeof item.price === 'number' ? item.price.toLocaleString('en-US') + ' USD' : 'Đang cập nhật';
        const positionValue = item.position || index + 1;
        const mobilePositionId = `mobile-position-${item._id}`;

    article.mobile-product-card(data-product-id=item._id)
        .mobile-product-card__head
            label.mobile-check
                input.row-checkbox(type="checkbox" name="selectedProducts[]" value=item._id)
                span Chọn sản phẩm
            if isActive
                span.chip.chip--success Hoạt động
            else
                span.chip.chip--danger Tạm ẩn
        .mobile-product-top
            img.product-thumb(src=thumb, alt=item.title || 'product')
            .mobile-product-summary
                .product-name= item.title || 'Chưa có tên sản phẩm'
                .product-desc= shortDesc
        .mobile-product-body
            .mobile-meta-grid
                .mobile-meta-card
                    strong Danh mục
                    span= item.category || 'Chưa phân loại'
                .mobile-meta-card
                    strong Giá
                    span= priceText
                .mobile-meta-card
                    strong Đánh giá
                    span= item.rating || 'Chưa có'
                .mobile-meta-card
                    strong Mã SP
                    span= item._id || index + 1
            .mobile-product-controls
                .mobile-control
                    span.mobile-control__label Trạng thái
                    label.switch
                        input.status-toggle(
                            type="checkbox",
                            checked=isActive,
                            data-id=item._id
                        )
                        span.slider
                .mobile-control
                    label.mobile-control__label(for=mobilePositionId) Vị trí hiển thị
                    input.position-input(
                        id=mobilePositionId
                        type="number"
                        min="1"
                        step="1"
                        value=positionValue
                        data-id=item._id
                        name="position"
                    )
            if item.discountPercentage
                .mobile-sale
                    span.price-sale Giảm #{item.discountPercentage}%
            +actionButtons(item)
