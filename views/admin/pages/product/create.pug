extends ../../layouts/default.pug

block main
  section.product-create-page
    .create-decor.create-decor--one
    .create-decor.create-decor--two
    .create-hero
      .create-hero__content
        span.create-hero__kicker Product Studio
        h1.create-hero__title Create new products
    .create-shell
      .create-panel
        form.create-product-form(
          action=`${PrefixAdmin}/product/create`
          id="form-create-product"
          method="POST"
          enctype="multipart/form-data"
        )
          .create-section
            .section-heading
              span.section-heading__eyebrow Key information
              h2.section-heading__title Product content
              p.section-heading__desc Fill in the basic information first; optional information can be left blank

            .create-grid
              .field-group.field-group--full
                label.field-label(for="title")
                  | Product title
                  span.required-badge Obligatory
                input#title.form-control-modern(
                  type="text"
                  name="title"
                  required
                  placeholder="For example: Bluetooth headset Pro X9"
                )

              .field-group.field-group--full
                label.field-label(for="description") Describe
                textarea#description.form-control-modern.form-control-modern--textarea(
                  name="description"
                  rows="5"
                  placeholder="A brief or detailed description of the product..."
                )

              .field-group
                label.field-label(for="category") Category
                input#category.form-control-modern(
                  type="text"
                  name="category"
                  placeholder="Example: Accessories"
                )

              .field-group
                label.field-label(for="position") Position
                input#position.form-control-modern(
                  type="number"
                  name="position"
                  min="0"
                  placeholder="Example: 1"
                )

          .create-section
            .section-heading
              span.section-heading__eyebrow Prices & reviews
              h2.section-heading__title Data displayed

            .create-grid
              .field-group
                label.field-label(for="price")
                  | Price
                  span.required-badge Obligatory
                .input-addon
                  input#price.form-control-modern(
                    type="number"
                    name="price"
                    min="0"
                    step="0.01"
                    required
                    placeholder="0"
                  )
                  span.input-addon__text USD

              .field-group
                label.field-label(for="discountPercentage")
                  | Discount (%)
                  span.required-badge Obligatory
                .input-addon
                  input#discountPercentage.form-control-modern(
                    type="number"
                    name="discountPercentage"
                    min="0"
                    max="100"
                    step="0.01"
                    required
                    placeholder="0"
                  )
                  span.input-addon__text %

              .field-group
                label.field-label(for="rating") Rating
                input#rating.form-control-modern(
                  type="number"
                  name="rating"
                  min="0"
                  max="5"
                  step="0.1"
                  placeholder="0 - 5"
                )

          .create-section
            .section-heading
              span.section-heading__eyebrow Status & photos
              h2.section-heading__title Additional settings

            .create-grid
              .field-group.field-group--full
                label.field-label
                  | Active
                  span.optional-note Choose a state
                .choice-grid
                  label.choice-card
                    input(type="radio" name="active" value="true" checked)
                    span.choice-card__content
                      strong Active
                      small The product is displayed normally.
                  label.choice-card
                    input(type="radio" name="active" value="false")
                    span.choice-card__content
                      strong Inactive
                      small Hide products from the display list

              .field-group.field-group--full
                label.field-label(for="images") Images
                input#images.form-control-modern.form-control-modern--file(
                  type="file"
                  name="images"
                  accept="image/*"
                  multiple
                )
          .form-footer
            p.form-footer__note Designed for product managers who need a clean draft flow before wiring backend logic.
            .form-footer__actions
              button.create-btn.create-btn--ghost(type="reset") Re-enter
              button.create-btn.create-btn--primary(type="submit") Save

      aside.create-sidebar
        .sidebar-card.sidebar-card--highlight
          span.sidebar-card__eyebrow Quick input
          h3 Quick input suggestion
          ul.sidebar-list
            li Titles should be short, clear, and under 70 characters
            li The discount should be entered as a percentage to match the model
            li Images are currently being used in a row-by-row format to make array separation easier later
            li The position can be left blank if manual sorting is not yet required

        .sidebar-card
          span.sidebar-card__eyebrow Preview card
          h3 Preview image
          .preview-card
            .preview-card__thumb
              span IMAGE
            .preview-card__body
              strong Tai nghe Bluetooth Pro X9
              p Âm thanh rõ, pin bền, thiết kế gọn cho nhu cầu di chuyển hằng ngày.
              .preview-card__meta
                span Price: $1,990
                span Discount: 15%
