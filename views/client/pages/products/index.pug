extends ../../layouts/default.pug

block main
    if featuredProduct
        .apple-products
            section.apl-ribbon
                p.apl-ribbon__text New season picks. Shop standout favorites and everyday essentials.

            section.apl-hero
                .apl-hero__copy
                    p.apl-hero__eyebrow= featuredProduct.category || "NTA Shop"
                    h1.apl-hero__title= featuredProduct.title || "Featured product"
                    p.apl-hero__desc= featuredProduct.description || "Fresh arrivals, beautifully presented and ready to explore."
                    .apl-hero__meta
                        span.apl-hero__price= featuredProduct.hasDiscount ? featuredProduct.formattedFinalPrice : featuredProduct.formattedRawPrice
                        if featuredProduct.hasDiscount
                            span.apl-hero__price-old= featuredProduct.formattedRawPrice
                        span.apl-hero__rating Rating #{featuredProduct.rating || 0}
                    .apl-hero__actions
                        a.apl-link(href="#highlights") Explore more
                        a.apl-link.apl-link--muted(href="#catalog") View lineup
                .apl-hero__visual
                    img(src=featuredProduct.imageSrc, alt=featuredProduct.title)

            if spotlightProducts.length > 0
                section#highlights(class=`apl-highlights ${spotlightProducts.length === 1 ? 'apl-highlights--single' : ''}`)
                    each product, index in spotlightProducts
                        article(class=`apl-highlight apl-highlight--${index === 0 ? 'light' : 'dark'}`)
                            .apl-highlight__copy
                                p.apl-section-kicker= product.category || "Collection"
                                h2.apl-highlight__title= product.title || "Featured story"
                                p.apl-highlight__desc= product.description || "A closer look at one of the standout products in the lineup."
                                .apl-highlight__meta
                                    span.apl-highlight__price= product.hasDiscount ? product.formattedFinalPrice : product.formattedRawPrice
                                    if product.hasDiscount
                                        span.apl-highlight__save Save #{product.formattedSavedAmount}
                            .apl-highlight__visual
                                img(src=product.imageSrc, alt=product.title)

            section.apl-specs
                .apl-spec
                    span.apl-spec__label Products
                    strong.apl-spec__value #{productStats.totalProducts}
                .apl-spec
                    span.apl-spec__label On sale
                    strong.apl-spec__value #{productStats.discountedCount}
                .apl-spec
                    span.apl-spec__label Main category
                    strong.apl-spec__value= productStats.leadingCategory
                .apl-spec
                    span.apl-spec__label Visible value
                    strong.apl-spec__value= productStats.totalInventoryValue

            if galleryProducts.length > 0
                section.apl-gallery
                    .apl-gallery__intro
                        p.apl-section-kicker Product lineup
                        h2.apl-gallery__title Designed to look striking from every angle.
                        p.apl-gallery__desc Large imagery, generous spacing, and clean typography keep the focus on every product.
                    .apl-gallery__grid(class=galleryProducts.length <= 3 ? 'apl-gallery__grid--feature' : '')
                        each product in galleryProducts
                            article.apl-gallery-card
                                .apl-gallery-card__image
                                    img(src=product.imageSrc, alt=product.title)
                                .apl-gallery-card__copy
                                    p.apl-gallery-card__category= product.category || "Collection"
                                    h3.apl-gallery-card__title= product.title || "Product"
                                    p.apl-gallery-card__price= product.hasDiscount ? product.formattedFinalPrice : product.formattedRawPrice

            if detailProducts.length > 0
                each product, index in detailProducts
                    section(class=`apl-story ${index % 2 === 1 ? 'apl-story--soft' : ''}`)
                        .apl-story__inner
                            .apl-story__copy
                                p.apl-section-kicker= product.category || "Highlights"
                                h2.apl-story__title= product.title || "Refined details"
                                p.apl-story__desc= product.description || "Thoughtful details, clear pricing, and a presentation that keeps the focus on the product."
                                .apl-story__facts
                                    span.apl-story__fact Price #{product.hasDiscount ? product.formattedFinalPrice : product.formattedRawPrice}
                                    if product.hasDiscount
                                        span.apl-story__fact Save #{product.formattedSavedAmount}
                                    span.apl-story__fact Rating #{product.rating || 0}
                            .apl-story__visual
                                img(src=product.imageSrc, alt=product.title)

            section#catalog.apl-catalog
                .apl-catalog__intro
                    p.apl-section-kicker Full catalog
                    h2.apl-catalog__title Every product has its own spotlight.
                    p.apl-catalog__desc Browse the full collection with refined cards, clearer pricing, and a lighter visual rhythm.

                .apl-catalog__meta
                    p.apl-catalog__count Showing #{pagination.startItem}-#{pagination.endItem} of #{pagination.totalProducts} products
                    if pagination.totalPages > 1
                        p.apl-catalog__page Page #{pagination.currentPage} / #{pagination.totalPages}

                .apl-catalog__grid
                    each product in products
                        article.apl-product
                            .apl-product__image
                                img(src=product.imageSrc, alt=product.title)
                            .apl-product__body
                                .apl-product__top
                                    span.apl-product__category= product.category || "Uncategorized"
                                    span.apl-product__rating ★ #{product.rating || 0}
                                h3.apl-product__title= product.title || "Product"
                                p.apl-product__text= product.description || "Details for this product are being updated."
                                .apl-product__bottom
                                    .apl-product__price
                                        span.apl-product__price-label Price
                                        if product.hasDiscount
                                            .apl-product__price-row
                                                span.apl-product__current= product.formattedFinalPrice
                                                span.apl-product__original= product.formattedRawPrice
                                            if product.savedAmount > 0
                                                span.apl-product__saving Save #{product.formattedSavedAmount}
                                        else
                                            .apl-product__price-row
                                                span.apl-product__current= product.formattedRawPrice
                                    .apl-product__actions
                                        a.apl-button.apl-button--ghost(href=product.detailPath) Xem chi tiết
                                        a.apl-button(href="#") Buy

                if pagination.totalPages > 1
                    nav.apl-pagination(aria-label="Product pagination")
                        if pagination.hasPrev
                            a.apl-pagination__nav(href=`/products?page=${pagination.prevPage}#catalog`) Previous
                        else
                            span.apl-pagination__nav.is-disabled Previous

                        .apl-pagination__pages
                            each pageNumber in pagination.pageNumbers
                                if pageNumber === pagination.currentPage
                                    span.apl-pagination__page.is-active= pageNumber
                                else
                                    a.apl-pagination__page(href=`/products?page=${pageNumber}#catalog`)= pageNumber

                        if pagination.hasNext
                            a.apl-pagination__nav(href=`/products?page=${pagination.nextPage}#catalog`) Next
                        else
                            span.apl-pagination__nav.is-disabled Next
    else
        .product-empty
            h2.product-empty__title No products found
            p.product-empty__desc Product data is currently unavailable. Please add items from the admin side and reload this page.


